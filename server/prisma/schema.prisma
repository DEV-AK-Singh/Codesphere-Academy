generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// User model
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  phone     String   @unique
  username  String   
  password  String
  role      Role     @default(USER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt  
  @@index([email])
  @@map("users")
}

// User roles
enum Role {
  ADMIN
  USER
  MODERATOR
}
